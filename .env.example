# Copy to .env and fill in before running your bot locally.

# Claude API (we will provide a capped key; any Claude model is fine).
ANTHROPIC_API_KEY=sk-ant-api03-...your-key-here...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Simulator base URL (we will send this to you).
SIMULATOR_BASE_URL=https://simulator-host.example/

# Your candidate token (we will send this to you). Required for prod runs.
CANDIDATE_TOKEN=your-candidate-token-here

# Control-plane shared secret for FastAPI routes (any random string).
CONTROL_PLANE_TOKEN=change-me-in-production

# Optional: path overrides
APP_DB_PATH=app.db
AUDIT_DB_PATH=audit.db
POLICY_FILE=policy_and_faq.md
POLICY_INDEX_PATH=policy_index.pkl

# Simulated current date (matches the data snapshot).
SIMULATED_NOW=2026-04-13

# Embeddings provider: 'sentence-transformers' (local) | 'voyage' (api)
EMBEDDINGS_PROVIDER=sentence-transformers
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
